{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.example/schemas/seo-bot/gate-evidence.schema.json",
  "title": "SEO Bot Gate Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "gate_id", "gate_class", "profile", "required", "status",
    "repository", "execution", "environment", "assertions", "findings", "blocked_by", "unknowns",
    "artifacts", "logs", "evidence_digest"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "gate_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "gate_class": { "enum": ["static", "build", "test", "database", "container", "integration", "operational", "release"] },
    "profile": { "enum": ["ci", "release", "production"] },
    "required": { "type": "boolean" },
    "status": { "$ref": "#/$defs/status" },
    "repository": { "$ref": "#/$defs/repository" },
    "execution": { "$ref": "#/$defs/execution" },
    "environment": { "$ref": "#/$defs/environment" },
    "assertions": { "type": "array", "items": { "$ref": "#/$defs/assertion" } },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "blocked_by": { "type": "array", "items": { "$ref": "#/$defs/blocker" } },
    "unknowns": { "type": "array", "items": { "$ref": "#/$defs/unknown" } },
    "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact" } },
    "logs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdout_path", "stderr_path", "redacted"],
      "properties": {
        "stdout_path": { "type": ["string", "null"] },
        "stderr_path": { "type": ["string", "null"] },
        "redacted": { "const": true }
      }
    },
    "evidence_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "status": { "enum": ["PASS", "PASS_WITH_FINDINGS", "BLOCKED", "FAIL", "UNKNOWN"] },
    "repository": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "commit_sha", "branch", "dirty"],
      "properties": {
        "name": { "const": "Quantum-L9/SEO-Bot" },
        "commit_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "branch": { "type": ["string", "null"] },
        "dirty": { "type": "boolean" }
      }
    },
    "execution": {
      "type": "object", "additionalProperties": false,
      "required": ["command", "cwd", "started_at", "completed_at", "duration_ms", "exit_code", "signal"],
      "properties": {
        "command": { "type": "array", "items": { "type": "string" } },
        "cwd": { "type": "string" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "exit_code": { "type": ["integer", "null"] },
        "signal": { "type": ["string", "null"] }
      }
    },
    "environment": {
      "type": "object", "additionalProperties": false,
      "required": ["ci", "os", "architecture", "node_version", "npm_version"],
      "properties": {
        "ci": { "type": "boolean" },
        "os": { "type": "string" },
        "architecture": { "type": "string" },
        "node_version": { "type": "string" },
        "npm_version": { "type": "string" }
      }
    },
    "assertion": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "description", "expected", "actual", "result"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "expected": {}, "actual": {},
        "result": { "enum": ["PASS", "FAIL", "UNKNOWN"] }
      }
    },
    "finding": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "severity", "message", "owner", "blocking", "evidence_refs"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "major", "minor", "info"] },
        "message": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "blocking": { "type": "boolean" },
        "evidence_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "blocker": {
      "type": "object", "additionalProperties": false,
      "required": ["type", "name", "reason"],
      "properties": {
        "type": { "enum": ["credential", "service", "dependency", "approval", "environment"] },
        "name": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "unknown": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "description", "required_resolution"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "required_resolution": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "media_type", "sha256", "size_bytes"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "media_type": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "size_bytes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}

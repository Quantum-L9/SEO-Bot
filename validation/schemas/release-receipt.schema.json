{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.example/schemas/seo-bot/release-receipt.schema.json",
  "title": "SEO Bot Release Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "repository", "image", "validation_run_id", "profile",
    "overall_status", "required_gates", "blocking_findings", "unknowns",
    "generated_at", "validation_digest", "receipt_digest"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "commit_sha", "branch", "dirty"],
      "properties": {
        "name": { "const": "Quantum-L9/SEO-Bot" },
        "commit_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "branch": { "type": ["string", "null"] },
        "dirty": { "type": "boolean" }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest"],
      "properties": {
        "digest": { "type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$" }
      }
    },
    "validation_run_id": { "type": "string", "minLength": 1 },
    "profile": { "enum": ["release", "production"] },
    "overall_status": { "enum": ["PASS", "PASS_WITH_FINDINGS", "BLOCKED", "FAIL", "UNKNOWN"] },
    "required_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "required", "status", "evidence_path", "evidence_digest"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "required": { "const": true },
          "status": { "enum": ["PASS", "PASS_WITH_FINDINGS", "BLOCKED", "FAIL", "UNKNOWN"] },
          "evidence_path": { "type": "string", "minLength": 1 },
          "evidence_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "severity", "message", "owner", "blocking", "evidence_refs"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["critical", "major", "minor", "info"] },
          "message": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "blocking": { "const": true },
          "evidence_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "required_resolution"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "required_resolution": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "validation_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "receipt_digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "allOf": [
    {
      "if": { "properties": { "overall_status": { "enum": ["PASS", "PASS_WITH_FINDINGS"] } } },
      "then": { "properties": { "image": { "properties": { "digest": { "type": "string" } } } } }
    }
  ]
}

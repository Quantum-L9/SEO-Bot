{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantum-l9.example/schemas/seo-bot/run-report.schema.json",
  "title": "SEO Bot Validation Run Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_version",
    "run_id",
    "profile",
    "repository",
    "started_at",
    "completed_at",
    "duration_ms",
    "overall_status",
    "gate_order",
    "gates",
    "blocking_findings",
    "unknowns",
    "run_digest"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "enum": [
        "ci",
        "release",
        "production"
      ]
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "commit_sha",
        "branch",
        "dirty"
      ],
      "properties": {
        "name": {
          "const": "Quantum-L9/SEO-Bot"
        },
        "commit_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "dirty": {
          "type": "boolean"
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "overall_status": {
      "enum": [
        "PASS",
        "PASS_WITH_FINDINGS",
        "BLOCKED",
        "FAIL",
        "UNKNOWN"
      ]
    },
    "gate_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate_id",
          "required",
          "status",
          "evidence_path",
          "evidence_digest"
        ],
        "properties": {
          "gate_id": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "status": {
            "enum": [
              "PASS",
              "PASS_WITH_FINDINGS",
              "BLOCKED",
              "FAIL",
              "UNKNOWN"
            ]
          },
          "evidence_path": {
            "type": "string"
          },
          "evidence_digest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unknown"
      }
    },
    "run_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "message",
        "owner",
        "blocking",
        "evidence_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "critical",
            "major",
            "minor",
            "info"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "const": true
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "unknown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "required_resolution"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "required_resolution": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
